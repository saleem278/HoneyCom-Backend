# ─────────────────────────────────────────────────────────────
# HoneyCom Backend — Environment Variables (example / template)
# Copy to .env (local), .env.sandbox, or .env.production and fill in.
# Committed file — placeholders only, NEVER real secrets.
#
# Brand resolution: DB settings (branding.*) → these env vars → neutral
# generic. Brand vars below seed branding.* on a fresh `npm run seed`.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (REQUIRED) ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/honeycom

# ── Auth (JWT, REQUIRED in production) ───────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=30d

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000

# ── Brand / App metadata ─────────────────────────────────────
APP_NAME=Your Store
APP_TAGLINE=Trusted Online Marketplace
APP_URL=https://www.example.com
COMPANY_ADDRESS=

# ── Support contacts ─────────────────────────────────────────
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=

# ── Social links (seeded into branding.social*) ──────────────
SOCIAL_FACEBOOK=
SOCIAL_TWITTER=
SOCIAL_INSTAGRAM=
SOCIAL_YOUTUBE=
SOCIAL_WHATSAPP=

# ── Email / SMTP (optional — only if using email features) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# ── Media / uploads — Cloudinary (optional) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Extra trusted image hosts (comma-separated) for the SSRF allowlist.
# res.cloudinary.com / cloudinary.com / images.unsplash.com always allowed.
ALLOWED_IMAGE_HOSTS=

# ── Social login — Google (optional) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Social login — Facebook (optional) ───────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Payments — Stripe (optional) ─────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Payments — Razorpay (optional) ───────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Commerce ─────────────────────────────────────────────────
BASE_CURRENCY=INR

# ── Rate limiting (optional — defaults applied if unset) ─────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Seed / dev helpers ───────────────────────────────────────
# Password for demo users created by the /seed endpoint.
SEED_USER_PASSWORD=ChangeMe2026
# Dev-only: include OTP in API responses for testing. MUST be false in prod.
EXPOSE_OTP_IN_RESPONSE=false
